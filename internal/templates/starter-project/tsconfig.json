{
    "compilerOptions": {
{{ if .InstallRageMPAdapter }}        "target": "es2020",
        "module": "commonjs",
        "moduleResolution": "node",
{{ else }}
        "target": "es2022",
        "module": "preserve",
        "moduleResolution": "bundler",
{{ end }}
        "skipLibCheck": true,
        "strict": true,
        "baseUrl": ".",
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "useDefineForClassFields": false,
        "outDir": "./dist",
        "noEmit": true,
{{ if .InstallRageMPAdapter }}        "types": ["node"]
{{ else }}        "types": ["@citizenfx/client", "@citizenfx/server"]
{{ end }}
    },
    "exclude": [
        "views",
        "dist",
        "node_modules"
    ]
}

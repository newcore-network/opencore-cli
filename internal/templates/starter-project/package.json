{
  "name": "{{.ProjectName}}",
  "version": "1.0.0",
  "private": true,
  "description": "OpenCore server project",
  "packageManager": "{{.PackageManager}}",
  "workspaces": [
    "core",
    "core/*/nui",
    "resources/*",
    "resources/*/ui",
    "resources/*/nui",
    "standalones/*",
    "views/*"
  ],
  "scripts": {
    "dev": "opencore dev",
    "build": "opencore build",
    "build:production": "opencore build --environment production"
  },
  "devDependencies": {
    "@open-core/cli": "latest",
    "vite": "^7.1.0",
    "typescript": "^5.3.3",
    "esbuild": "^0.27.4",
    "@swc/core": "^1.15.7",
    "tsconfig-paths": "^4.2.0"{{if .InstallRageMPAdapter}},
    "@types/node": "^14.18.63",
    "@ragempcommunity/types-server": "latest",
    "@ragempcommunity/types-client": "latest"{{end}}
  },
  "dependencies": {
{{ if .InstallFiveMAdapter }}    "@citizenfx/client": "2.0.22443-1",
    "@citizenfx/server": "2.0.22443-1",
{{ end }}
    "reflect-metadata": "^0.2.2",
    "@open-core/framework": "latest"{{if .InstallFiveMAdapter}},
    "@open-core/fivem-adapter": "latest"{{end}}{{if .InstallRageMPAdapter}},
    "@open-core/ragemp-adapter": "latest"{{end}}{{if .InstallIdentity}},
    "@open-core/identity": "latest"{{end}}
  }
}

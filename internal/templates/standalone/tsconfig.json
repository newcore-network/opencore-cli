{
  "compilerOptions": {
    "target": "{{.TSConfigTarget}}",
    "module": "{{.TSConfigModule}}",
    "moduleResolution": "{{.TSModuleResolution}}",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true,
{{if .UseNodeTypes}}    "types": ["node", "@ragempcommunity/types-server", "@ragempcommunity/types-client"]
{{else}}    "types": ["@citizenfx/client", "@citizenfx/server"]
{{end}}  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
